# Copy to `.env` (or let `npm run env:env` generate it from Infisical).
# All values are examples and MUST be replaced for non-local use.

NODE_ENV=development
SIGNUM_PORT=3200
SIGNUM_WEB_PORT=8083
SIGNUM_CORS_ORIGINS=http://localhost:8083,http://localhost:5173

# Cernere
CERNERE_URL=http://localhost:3000
JWT_SECRET=
TOOL_CLIENT_ID=
TOOL_CLIENT_SECRET=

# Shared infra (LUDIARS/Infra) — per-service DB number.
SIGNUM_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/signum
SIGNUM_REDIS_URL=redis://localhost:6379/4

# Standalone (docker-compose.standalone.yaml) overrides
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=signum
