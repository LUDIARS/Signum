{
  "name": "signum",
  "version": "0.0.1",
  "private": true,
  "description": "Signum — LUDIARS web service scaffold (AIFormat compliant).",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev":        "npm run env:env && npx dotenv-cli -- concurrently -n api,web -c green,cyan \"tsx watch src/index.ts\" \"npm run dev --prefix frontend\"",
    "dev:server": "npx dotenv-cli -- tsx watch src/index.ts",
    "dev:front":  "npx dotenv-cli -- npm run dev --prefix frontend",
    "build":      "tsc -p tsconfig.json",
    "build:front":"npm run build --prefix frontend",
    "start":      "node dist/index.js",
    "db:generate":"drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:init":    "tsx src/db/migrate.ts",
    "env:setup":      "npx tsx ../Cernere/packages/env-cli/src/cli.ts setup",
    "env:test":       "npx tsx ../Cernere/packages/env-cli/src/cli.ts test",
    "env:env":        "npx tsx ../Cernere/packages/env-cli/src/cli.ts env",
    "env:initialize": "npx tsx ../Cernere/packages/env-cli/src/cli.ts initialize",
    "env:up":            "npm run env:env && docker compose up -d",
    "env:up:prod":       "npm run env:env && docker compose up -d",
    "env:up:standalone": "npm run env:env && docker compose -f docker-compose.yaml -f docker-compose.standalone.yaml up -d",
    "test": "vitest run",
    "ci-check": "bash scripts/ci-check.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LUDIARS/Signum"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws":     "^1.3.0",
    "@ludiars/cernere-id-cache":   "^0.1.0",
    "@ludiars/cernere-id-service": "^0.1.0",
    "bcryptjs":        "^3.0.3",
    "drizzle-orm":     "^0.45.1",
    "hono":            "^4.12.8",
    "ioredis":         "^5.10.0",
    "jsonwebtoken":    "^9.0.3",
    "pngjs":           "^7.0.0",
    "postgres":        "^3.4.8",
    "uuid":            "^13.0.0",
    "ws":              "^8.20.0",
    "zod":             "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs":     "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node":         "^22.9.0",
    "@types/pngjs":        "^6.0.5",
    "@types/uuid":         "^10.0.0",
    "@types/ws":           "^8.18.1",
    "concurrently":        "^9.2.1",
    "dotenv-cli":          "^11.0.0",
    "drizzle-kit":         "^0.31.9",
    "tsx":                 "^4.21.0",
    "typescript":          "^5.9.3",
    "vitest":              "^4.1.0"
  }
}
